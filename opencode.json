{
    "$schema": "https://opencode.ai/config.json",
    "permission": {
        "bash": {
            "*": "ask",
            "git *": "allow",
            "git commit *": "deny",
            "git push *": "deny",
            "grep *": "allow"
        },
        "read": {
            "*": "allow",
            "*.env": "deny",
            "*.env.*": "deny",
            "*.env.example": "allow"
        }
    },
    "agent": {
        "build": {
            "permission": {
                "bash": {
                    "*": "ask",
                    "rm *": "ask",
                    "git *": "allow",
                    "git commit *": "ask",
                    "git push *": "deny",
                    "grep *": "allow"
                }
            }
        }
    }
}
