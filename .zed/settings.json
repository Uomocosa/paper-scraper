{
    "format_on_save": "off",
    "languages": {
        "Python": {
            "enable_language_server": false,
        },
    },
    "terminal": {
        "detect_venv": "off",
    },
    "file_scan_exclusions": [
        // "**/.venv",
        "**/build",
        "**/target",
        "**/node_modules",
        "**/*.log",
        "**/_old",
        "**/.vscode",
        "**/__pycache__",
        "**/.pytest_cache",
        "**/*.egg-info",
        "**/.git",
        "**/.svn",
        "**/.hg",
        "**/CVS",
        "**/.DS_Store",
        "**/Thumbs.db",
    ],
}
