[
    {
        "label": "run",
        "command": "pixi run pytest -rFP -q -s $ZED_RELATIVE_FILE -o \"addopts=\"",
        "env": { "LOGURU_LEVEL": "DEBUG" },
        "use_new_terminal": false,
        "allow_concurrent_runs": false,
        "reveal": "always",
        "hide": "never",
        "shell": "system",
        "show_summary": false,
        "show_command": true,
    },
    { // Substitute the runnables near "test_" functions
        "label": "${ZED_FILENAME}::${ZED_SYMBOL:entire file}",
        "command": "pixi run pytest -rFP -q -s $ZED_CUSTOM_PYTHON_TEST_TARGET -o \"addopts=\"",
        "tags": ["python-pytest-method", "python-pytest-class"],
    },
    {
        "label": "RUN_ALL_TESTS",
        "command": "pixi run pytest -m 'not verbose and not todo and not above10s and not unreliable and not infinite' --durations=10 .",
